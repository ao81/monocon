*.exe filter=lfs diff=lfs merge=lfs -text

* text=auto
*.bat text eol=crlf
*.sh text eol=lf
*.ps1 text eol=crlf
*.json text eol=lf
*.cpp text eol=lf
*.h text eol=lf

*.exe binary
*.dll binary
*.bin binary
*.png binary
*.jpg binary

# VSCode policies (Windows Group Policy format - requires CRLF)
*.admx text eol=crlf
*.adml text eol=crlf

# Serial monitor extension and similar (LF on disk, CRLF on Windows checkout)
*.vsixmanifest text eol=crlf
*.md text eol=crlf
*.txt text eol=crlf
*.ts text eol=lf
*.cc text eol=lf
*.c text eol=lf
*.gyp text eol=lf
*.gypi text eol=lf
*.coffee text eol=lf