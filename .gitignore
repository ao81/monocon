# ============================================
# VSCode (Portable) - 自動生成されるファイル
# ============================================

# ユーザーデータ内のキャッシュ・ログ・一時データ
vscode/data/user-data/Backups/
vscode/data/user-data/blob_storage/
vscode/data/user-data/Cache/
vscode/data/user-data/CachedConfigurations/
vscode/data/user-data/CachedData/
vscode/data/user-data/CachedProfilesData/
vscode/data/user-data/clp/
vscode/data/user-data/Code Cache/
vscode/data/user-data/Crashpad/
vscode/data/user-data/DawnGraphiteCache/
vscode/data/user-data/DawnWebGPUCache/
vscode/data/user-data/GPUCache/
vscode/data/user-data/Local Storage/
vscode/data/user-data/logs/
vscode/data/user-data/Network/
vscode/data/user-data/Service Worker/
vscode/data/user-data/Session Storage/
vscode/data/user-data/Shared Dictionary/
vscode/data/user-data/WebStorage/

# ユーザーのワーク履歴・チャット履歴
vscode/data/user-data/User/History/
vscode/data/user-data/User/globalStorage/
vscode/data/user-data/User/workspaceStorage/

# 共有ストレージ
vscode/data/shared-data/

# ============================================
# CMake ビルド中間ファイル（bin/ の成果物は残す）
# ============================================
data/daemon/build/*
!data/daemon/build/bin/

# ============================================
# OS の一時ファイル
# ============================================
Thumbs.db
Desktop.ini
ehthumbs.db
.DS_Store

# ============================================
# Node.js
# ============================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================
# その他
# ============================================
debug.log
vscode/data/cache/
code.lock
*-wal
DIPS