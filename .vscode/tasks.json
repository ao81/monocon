{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Arduino: Build & Upload",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-NonInteractive",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}/.vscode/arduino-upload.ps1",
				"-BuildPath",
				"${workspaceFolder}/.arduino-build",
				"-SketchDir",
				"${fileDirname}",
				"-Port",
				"COM6"
			],
			"group": { "kind": "build", "isDefault": true },
			"presentation": {
				"reveal": "always",
				"panel": "shared",
				"echo": false,
				"clear": true
			},
			"problemMatcher": []
		}
	]
}
