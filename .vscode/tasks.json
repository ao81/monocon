		{
			"label": "Arduino: Build & Upload",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-NonInteractive",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}/.vscode/arduino-upload.ps1",
				"-BuildPath",
				"${workspaceFolder}/.vscode/build/${relativeFileDirname}",
				"-SketchDir",
				"${fileDirname}"
			],
			"group": { "kind": "build", "isDefault": true },
			"presentation": {
				"reveal": "always",
				"panel": "shared",
				"echo": false,
				"clear": true
			},
			"problemMatcher": []
		},


