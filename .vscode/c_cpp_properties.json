{
	"configurations": [
		{
			"name": "Arduino",
			"includePath": [
				"${workspaceFolder}/**",
				"${env:USERPROFILE}/AppData/Local/Arduino15/packages/arduino/hardware/avr/*/cores/arduino/**",
				"${env:USERPROFILE}/AppData/Local/Arduino15/packages/arduino/hardware/avr/*/variants/mega/**",
				"${env:USERPROFILE}/AppData/Local/Arduino15/packages/arduino/hardware/avr/*/libraries/**",
				"${env:USERPROFILE}/AppData/Local/Arduino15/libraries/**"
			],
			"defines": ["ARDUINO=10819", "F_CPU=16000000L", "__AVR_ATmega2560__"],
			"cStandard": "c11",
			"cppStandard": "c++17",
			"intelliSenseMode": "gcc-x64"
		}
	],
	"version": 4
}
