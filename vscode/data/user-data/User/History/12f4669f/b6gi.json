// 既定値を上書きするには、このファイル内にキー バインドを挿入します
[
	// =====================================================================
	// フォーマット: Ctrl+B
	// =====================================================================
	{
		"key": "ctrl+b",
		"command": "editor.action.formatDocument",
		"when": "editorHasDocumentFormattingProvider && editorTextFocus && !editorReadonly && !inCompositeEditor"
	},
	{
		"key": "shift+alt+f",
		"command": "-editor.action.formatDocument",
		"when": "editorHasDocumentFormattingProvider && editorTextFocus && !editorReadonly && !inCompositeEditor"
	},
	{
		"key": "ctrl+b",
		"command": "editor.action.formatDocument.none",
		"when": "editorTextFocus && !editorHasDocumentFormattingProvider && !editorReadonly"
	},
	{
		"key": "shift+alt+f",
		"command": "-editor.action.formatDocument.none",
		"when": "editorTextFocus && !editorHasDocumentFormattingProvider && !editorReadonly"
	},
	{
		"key": "ctrl+b",
		"command": "notebook.format",
		"when": "notebookEditable && !editorTextFocus && activeEditor == 'workbench.editor.notebook'"
	},
	{
		"key": "shift+alt+f",
		"command": "-notebook.format",
		"when": "notebookEditable && !editorTextFocus && activeEditor == 'workbench.editor.notebook'"
	},
	{
		"key": "ctrl+b",
		"command": "-workbench.action.toggleSidebarVisibility"
	},
	{
		"key": "ctrl+b",
		"command": "-markdown.extension.editing.toggleBold",
		"when": "editorTextFocus && !editorReadonly && editorLangId =~ /^markdown$|^rmd$|^quarto$/"
	},
	{
		"key": "ctrl+b",
		"command": "-extension.vim_ctrl+b",
		"when": "editorTextFocus && vim.active && vim.use<C-b> && !inDebugRepl && vim.mode != 'Insert'"
	},

	// =====================================================================
	// Code Runner: F1
	// =====================================================================
	{
		"key": "f1",
		"command": "code-runner.run"
	},
	{
		"key": "ctrl+alt+n",
		"command": "-code-runner.run"
	},
	{
		"key": "f1",
		"command": "-workbench.action.showCommands"
	},

	// =====================================================================
	// コマンドパレット: F8
	// =====================================================================
	{
		"key": "f8",
		"command": "workbench.action.showCommands"
	},
	{
		"key": "f8",
		"command": "-editor.action.marker.nextInFiles",
		"when": "editorFocus"
	},

	// =====================================================================
	// インデントをタブに変換: Alt+C
	// =====================================================================
	{
		"key": "alt+c",
		"command": "editor.action.indentationToTabs"
	},
	{
		"key": "alt+c",
		"command": "-toggleFindCaseSensitive",
		"when": "editorFocus"
	},
	{
		"key": "alt+c",
		"command": "-toggleSearchCaseSensitive",
		"when": "searchViewletFocus"
	},
	{
		"key": "alt+c",
		"command": "-toggleSearchEditorCaseSensitive",
		"when": "inSearchEditor && searchInputBoxFocus"
	},
	{
		"key": "alt+c",
		"command": "-workbench.action.terminal.toggleFindCaseSensitive",
		"when": "terminalFindVisible && terminalHasBeenCreated || terminalFindVisible && terminalProcessSupported"
	},
	{
		"key": "alt+c",
		"command": "-markdown.extension.checkTaskList",
		"when": "editorTextFocus && editorLangId =~ /^markdown$|^rmd$|^quarto$/"
	},

	// =====================================================================
	// 全選択: Ctrl+A (Vim モード外) / Alt+A
	// =====================================================================
	{
		"key": "alt+a",
		"command": "editor.action.selectAll"
	},
	// Vim が無効なとき (通常エディタ) は Ctrl+A でも全選択できるようにする
	{
		"key": "ctrl+a",
		"command": "editor.action.selectAll",
		"when": "editorTextFocus && (!vim.active || vim.mode == 'Insert')"
	},
	{
		"key": "ctrl+a",
		"command": "-editor.action.selectAll"
	},
	{
		"key": "ctrl+a",
		"command": "-extension.vim_ctrl+a",
		"when": "editorTextFocus && vim.active && vim.use<C-a> && !inDebugRepl"
	},
	{
		"key": "ctrl+a",
		"command": "-list.selectAll",
		"when": "listFocus && listSupportsMultiselect && !inputFocus && !treestickyScrollFocused"
	},

	// =====================================================================
	// Vim: Alt+Y → Ctrl+Y 相当
	// =====================================================================
	{
		"key": "alt+y",
		"command": "extension.vim_ctrl+y",
		"when": "editorTextFocus && vim.active && vim.use<C-y> && !inDebugRepl"
	},
	{
		"key": "ctrl+y",
		"command": "-extension.vim_ctrl+y",
		"when": "editorTextFocus && vim.active && vim.use<C-y> && !inDebugRepl"
	},

	// =====================================================================
	// シンボルのリネーム: F3
	// =====================================================================
	{
		"key": "f3",
		"command": "editor.action.rename"
	},
	{
		"key": "f3",
		"command": "-workbench.action.terminal.findNext",
		"when": "terminalFindFocused && terminalHasBeenCreated || terminalFindFocused && terminalProcessSupported || terminalFocusInAny && terminalHasBeenCreated || terminalFocusInAny && terminalProcessSupported"
	},
	{
		"key": "shift+f3",
		"command": "-workbench.action.terminal.findPrevious",
		"when": "terminalFindFocused && terminalHasBeenCreated || terminalFindFocused && terminalProcessSupported || terminalFocusInAny && terminalHasBeenCreated || terminalFocusInAny && terminalProcessSupported"
	},

	// =====================================================================
	// 同名シンボルを全て変更: Ctrl+F3
	// =====================================================================
	{
		"key": "ctrl+f3",
		"command": "editor.action.changeAll",
		"when": "editorTextFocus && !editorReadonly"
	},
	{
		"key": "ctrl+f2",
		"command": "-editor.action.changeAll",
		"when": "editorTextFocus && !editorReadonly"
	},

	// =====================================================================
	// Arduino アップロード: F2
	// =====================================================================
	{
		"key": "f2",
		"command": "workbench.action.tasks.runTask",
		"args": "Arduino: Upload"
	},
	{
		"key": "f2",
		"command": "-editor.action.rename",
		"when": "editorHasRenameProvider && editorTextFocus && !editorReadonly"
	},
	{
		"key": "f2",
		"command": "-renameFile",
		"when": "filesExplorerFocus && foldersViewVisible && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus"
	},
	{
		"key": "f2",
		"command": "-workbench.action.terminal.renameActiveTab",
		"when": "terminalHasBeenCreated && terminalTabsFocus && terminalTabsSingularSelection || terminalProcessSupported && terminalTabsFocus && terminalTabsSingularSelection"
	},
	{
		"key": "f2",
		"command": "-debug.renameWatchExpression",
		"when": "watchExpressionsFocused"
	},
	{
		"key": "f2",
		"command": "-debug.setVariable",
		"when": "variablesFocused"
	},
	{
		"key": "f2",
		"command": "-agentSession.rename",
		"when": "agentSessionsViewerFocused && !agentSessionHasMultipleSelected && chatSessionType == 'local'"
	},
	{
		"key": "f2",
		"command": "-java.view.package.renameFile",
		"when": "focusedView == 'javaProjectExplorer' && java:serverMode == 'Standard'"
	},
	{
		"key": "f2",
		"command": "-remote.tunnel.label",
		"when": "tunnelViewFocus && tunnelType == 'Forwarded' && tunnelViewMultiSelection == 'undefined'"
	},

	// =====================================================================
	// チャットを開く: Alt+I
	// =====================================================================
	{
		"key": "alt+i",
		"command": "workbench.action.chat.open",
		"when": "!chatSetupDisabled && !chatSetupHidden"
	},
	{
		"key": "ctrl+alt+i",
		"command": "-workbench.action.chat.open",
		"when": "!chatSetupDisabled && !chatSetupHidden"
	},

	// =====================================================================
	// タスクビルド: Ctrl+Space
	// =====================================================================
	{
		"key": "ctrl+space",
		"command": "workbench.action.tasks.build",
		"when": "taskCommandsRegistered"
	},
	{
		"key": "ctrl+shift+b",
		"command": "-workbench.action.tasks.build",
		"when": "taskCommandsRegistered"
	},
	{
		"key": "ctrl+space",
		"command": "-editor.action.triggerSuggest",
		"when": "editorHasCompletionItemProvider && textInputFocus && !editorReadonly && !suggestWidgetVisible"
	},
	{
		"key": "ctrl+space",
		"command": "-workbench.action.terminal.sendSequence",
		"when": "config.terminal.integrated.enableWin32InputMode && terminalFocus && terminalShellIntegrationEnabled && !accessibilityModeEnabled && terminalShellType == 'pwsh'"
	},
	{
		"key": "ctrl+space",
		"command": "-workbench.action.terminal.triggerSuggest",
		"when": "config.terminal.integrated.suggest.enabled && terminalFocus && terminalProcessSupported && !terminalSuggestWidgetVisible"
	},
	{
		"key": "ctrl+space",
		"command": "-toggleSuggestionDetails",
		"when": "suggestWidgetHasFocusedSuggestion && suggestWidgetVisible && textInputFocus"
	},
	{
		"key": "ctrl+space",
		"command": "-focusSuggestion",
		"when": "suggestWidgetVisible && textInputFocus && !suggestWidgetHasFocusedSuggestion"
	},
	{
		"key": "ctrl+space",
		"command": "-extension.vim_ctrl+space",
		"when": "editorTextFocus && vim.active && vim.use<C-space> && !inDebugRepl && vim.mode != 'Insert'"
	},
	{
		"key": "ctrl+space",
		"command": "-workbench.action.terminal.suggestToggleDetails",
		"when": "simpleSuggestWidgetHasFocusedSuggestion && terminalFocus && terminalHasBeenCreated && terminalIsOpen && terminalSuggestWidgetVisible || simpleSuggestWidgetHasFocusedSuggestion && terminalFocus && terminalIsOpen && terminalProcessSupported && terminalSuggestWidgetVisible"
	},
	{
		"key": "ctrl+space",
		"command": "-quickInput.toggleHover",
		"when": "inQuickInput && quickInputType == 'quickPick' || inQuickInput && quickInputType == 'quickTree'"
	},

	// =====================================================================
	// ターミナル: Ctrl+Backspace の競合解除
	// =====================================================================
	{
		"key": "ctrl+backspace",
		"command": "-workbench.action.terminal.sendSequence",
		"when": "terminalFocus"
	},

	// =====================================================================
	// Vim: Ctrl+C / Ctrl+V の競合解除
	// =====================================================================
	{
		"key": "ctrl+c",
		"command": "-extension.vim_ctrl+c",
		"when": "editorTextFocus && vim.active && vim.overrideCtrlC && vim.use<C-c> && !inDebugRepl"
	},
	{
		"key": "ctrl+v",
		"command": "-extension.vim_ctrl+v",
		"when": "editorTextFocus && vim.active && vim.use<C-v> && !inDebugRepl"
	},
	{
		"key": "ctrl+v",
		"command": "-workbench.action.terminal.pastePwsh",
		"when": "terminalFocus && !accessibilityModeEnabled && terminalShellType == 'pwsh'"
	},

	// =====================================================================
	// ファイルエクスプローラー: Ctrl+C / Ctrl+V
	// ★ when 条件を付けて、エクスプローラーにフォーカスがある時だけ有効にする
	// =====================================================================
	{
		"key": "ctrl+c",
		"command": "filesExplorer.copy",
		"when": "filesExplorerFocus && foldersViewVisible && !explorerResourceIsRoot && !inputFocus"
	},
	{
		"key": "ctrl+v",
		"command": "filesExplorer.paste",
		"when": "filesExplorerFocus && foldersViewVisible && !explorerResourceReadonly && !inputFocus"
	},
	{
		"key": "ctrl+backspace",
		"command": "-extension.vim_ctrl+backspace",
		"when": "editorTextFocus && vim.active && vim.use<C-BS> && !inDebugRepl && vim.mode != 'Insert'"
	},
	{
		"key": "ctrl+unknown",
		"command": "-extension.vim_ctrl+^",
		"when": "editorTextFocus && vim.active && vim.use<C-^> && !inDebugRepl"
	}
]