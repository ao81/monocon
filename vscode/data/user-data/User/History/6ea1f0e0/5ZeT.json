{
	"digitalWrite": {
		"prefix": "dw",
		"body": "digitalWrite(${1}, ${2|HIGH,LOW|});",
		"description": "Set a digital pin HIGH or LOW"
	},
	"digitalRead": {
		"prefix": "dr",
		"body": "digitalRead(${1});",
		"description": "Read a digital pin"
	},
	"analogWrite": {
		"prefix": "aw",
		"body": "analogWrite(${1}, ${2});",
		"description": "Write PWM value (0-255)"
	},
	"analogRead": {
		"prefix": "ar",
		"body": "analogRead(${1});",
		"description": "Read an analog pin (0-1023)"
	},
	"Serial.begin": {
		"prefix": "sb",
		"body": "Serial.begin(9600);",
		"description": "Initialize serial communication"
	},
	"Serial.println": {
		"prefix": "sp",
		"body": "Serial.println(\"${1}\");",
		"description": "Print with newline"
	},
	"USER_CON_1PIN": {
		"prefix": "_1",
		"body": "_USER_CON_1PIN"
	},
