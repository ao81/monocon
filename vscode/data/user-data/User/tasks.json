{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Arduino: Upload",
			"type": "process",
			"command": "${execPath}/../data/daemon/build/bin/arduino-build-cli.exe",
			"args": ["upload", "${fileDirname}", "--workspace", "${workspaceFolder}"],
			"group": { "kind": "build", "isDefault": true },
			"presentation": { "reveal": "always", "panel": "shared", "clear": true },
			"problemMatcher": []
		}
	]
}
