{
	"digitalWrite": {
		"prefix": "dw",
		"body": "digitalWrite(${1}, ${2});",
	},
	"digitalRead": {
		"prefix": "dr",
		"body": "digitalRead(${1});",
	},
	"analogWrite": {
		"prefix": "aw",
		"body": "analogWrite(${1}, ${2});",
	},
	"analogRead": {
		"prefix": "ar",
		"body": "analogRead(${1});",
	},
	"random": {
		"prefix": "random",
		"body": "random(${1:min}, ${2:max})",
	},
	"randomSeed": {
		"prefix": "randomseed",
		"body": "randomSeed(${1:analogRead(0)});",
	},
	"noInterrupts": {
		"prefix": "nointerrupts",
		"body": "noInterrupts();",
	},
	"interrupts": {
		"prefix": "interrupts",
		"body": "interrupts();",
	},
	"tone": {
		"prefix": "tone",
		"body": "tone(${1}, ${2});",
	},
	"noTone": {
		"prefix": "notone",
		"body": "noTone(${1});",
	},
	"Serial.begin": {
		"prefix": "sb",
		"body": "Serial.begin(9600);",
	},
	"Serial.println": {
		"prefix": "sp",
		"body": "Serial.println(\"${1}\");",
	},
	"constrain": {
		"prefix": "constrain",
		"body": "constrain(${1}, ${2}, ${3})",
	},
	"USER_CON_1PIN": {
		"prefix": "_1",
		"body": "_USER_CON_1PIN"
	},
	"USER_CON_2PIN": {
		"prefix": "_2",
		"body": "_USER_CON_2PIN"
	},
	"USER_CON_3PIN": {
		"prefix": "_3",
		"body": "_USER_CON_3PIN"
	},
	"USER_CON_4PIN": {
		"prefix": "_4",
		"body": "_USER_CON_4PIN"
	},
	"USER_CON_5PIN": {
		"prefix": "_5",
		"body": "_USER_CON_5PIN"
	},
	"USER_CON_6PIN": {
		"prefix": "_6",
		"body": "_USER_CON_6PIN"
	},
	"USER_CON_7PIN": {
		"prefix": "_7",
		"body": "_USER_CON_7PIN"
	},
	"USER_CON_8PIN": {
		"prefix": "_8",
		"body": "_USER_CON_8PIN"
	}
}