{
	// =========================================================
	// Editor
	// =========================================================
	"editor.fontFamily": "'Source Code Pro'",
	"editor.fontLigatures": true,
	"editor.tabSize": 4,
	"editor.insertSpaces": false,
	"editor.autoIndentOnPaste": true,
	"editor.wrappingIndent": "indent",
	"editor.smoothScrolling": true,
	"editor.mouseWheelZoom": true,
	"editor.showFoldingControls": "always",
	"editor.stickyScroll.enabled": false,
	"editor.minimap.side": "left",
	"editor.minimap.size": "fill",
	"editor.minimap.showSlider": "always",
	"editor.codeLens": false,
	"editor.codeLensFontFamily": "'Consolas'",
	// "editor.formatOnSave": true,
	"editor.snippetSuggestions": "top",
	"editor.wordBasedSuggestionsMode": "matchingDocuments",
	"editor.formatOnPaste": true,
	"editor.defaultFormatter": "ms-vscode.cpptools",
	"editor.wordWrap": "on", // 行の折り返し
	"editor.quickSuggestions": {
		"comments": "on",
		"strings": "on"
	},

	// =========================================================
	// Formatter (per language)
	// =========================================================
	"[c]": {
		"editor.defaultFormatter": "ms-vscode.cpptools"
	},
	"[cpp]": {
		"editor.defaultFormatter": "ms-vscode.cpptools",
		"editor.snippetSuggestions": "top"
	},

	// =========================================================
	// C / C++
	// =========================================================
	"C_Cpp.formatting": "vcFormat",
	"C_Cpp.vcFormat.newLine.beforeOpenBrace.block": "sameLine",
	"C_Cpp.vcFormat.newLine.beforeOpenBrace.function": "sameLine",
	"C_Cpp.vcFormat.newLine.beforeOpenBrace.lambda": "sameLine",
	"C_Cpp.vcFormat.newLine.beforeOpenBrace.namespace": "sameLine",
	"C_Cpp.vcFormat.newLine.beforeOpenBrace.type": "sameLine",
	"C_Cpp.vcFormat.newLine.beforeElse": false,
	"C_Cpp.vcFormat.newLine.beforeCatch": false,
	"C_Cpp.vcFormat.newLine.closeBraceSameLine.emptyFunction": true,
	"C_Cpp.vcFormat.space.beforeFunctionOpenParenthesis": "remove",
	"C_Cpp.vcFormat.indent.multiLineRelativeTo": "outermostParenthesis",
	// "C_Cpp.default.compilerPath": "C:/Program Files (x86)/mingw64/bin/gcc.exe",
	"C_Cpp.intelliSenseEngine": "default",
	"clang-format.style": "{ BasedOnStyle: LLVM, IndentWidth: 4, UseTab: Always, TabWidth: 4 }",
	"clang-format.fallbackStyle": "LLVM",

	"C_Cpp.default.browse.path": [
		"${fileDirname}",
		"${env:LOCALAPPDATA}/Arduino15/packages/arduino/hardware/avr/1.8.7/cores/arduino",
		"${env:LOCALAPPDATA}/Arduino15/packages/arduino/hardware/avr/1.8.7/variants/mega",
		"${env:LOCALAPPDATA}/Arduino15/packages/arduino/hardware/avr/1.8.7/libraries/**",
		"${env:USERPROFILE}/Documents/Arduino/libraries/**"
	],
	"C_Cpp.default.limitSymbolsToIncludedHeaders": true,
	"editor.parameterHints.enabled": false,

	// =========================================================
	// Terminal
	// =========================================================
	"terminal.integrated.fontFamily": "monospace",
	"terminal.integrated.gpuAcceleration": "on",
	"terminal.integrated.unicodeVersion": "11",
	"terminal.integrated.detectLocale": "off",
	"terminal.integrated.enableMultiLinePasteWarning": "never",
	"terminal.integrated.allowedLinkSchemes": [
		"file",
		"http",
		"https",
		"mailto",
		"vscode",
		"vscode-insiders",
		"ms-settings"
	],
	"terminal.integrated.suggest.quickSuggestions": {
		"commands": "on",
		"arguments": "on",
		"unknown": "on"
	},

	// =========================================================
	// Files  ([追加] 自動保存・データ保護)
	// =========================================================
	// "files.autoSave": "afterDelay",
	// "files.autoSaveDelay": 1000,
	"files.hotExit": "onExitAndWindowClose",
	"files.trimTrailingWhitespace": true,
	"files.insertFinalNewline": true,
	"files.trimFinalNewlines": true,
	"files.autoGuessEncoding": false,

	// =========================================================
	// Workbench
	// =========================================================
	"workbench.startupEditor": "none",
	"workbench.iconTheme": "vscode-icons",
	"workbench.editor.empty.hint": "hidden",
	"workbench.editor.enablePreview": false,
	"workbench.secondarySideBar.defaultVisibility": "hidden",
	"workbench.settings.applyToAllProfiles": [
		"editor.tabSize",
		"editor.formatOnSave",
		"editor.fontFamily"
	],

	// =========================================================
	// Explorer
	// =========================================================
	"explorer.confirmDelete": false,
	"explorer.confirmDragAndDrop": false,
	"explorer.confirmPasteNative": false,
	"explorer.compactFolders": false,

	// =========================================================
	// Arduino
	// =========================================================
	"arduino.commandPath": "arduino-cli",
	"arduino.logLevel": "info",
	"arduino.enableUSBDetection": true,
	"arduino.disableTestingOpen": false,
	"arduino.skipHeaderProvider": false,
	"arduino.defaultBaudRate": 9600,
	"arduino.additionalUrls": [
		"https://dl.espressif.com/dl/package_esp32_index.json"
	],
	"arduino.ignoreBoards": [],

	// =========================================================
	// File associations
	// =========================================================
	"files.associations": {
		"*.ino": "cpp"
	},

	// =========================================================
	// Indent Rainbow
	// =========================================================
	"indentRainbow.colors": [
		"rgba(255,255,64,0.07)",
		"rgba(127,255,127,0.07)",
		"rgba(255,127,255,0.07)",
		"rgba(79,236,236,0.07)"
	],
	"indentRainbow.errorColor": "rgba(255,255,255,0.3)",
	"indentRainbow.updateDelay": 10,

	// =========================================================
	// Terminal Settings
	// =========================================================
	"terminal.integrated.defaultProfile.windows": "Command Prompt",
	"terminal.integrated.profiles.windows": {
		"PowerShell": {
			"source": "PowerShell",
			"icon": "terminal-powershell"
		},
		"Command Prompt": {
			"path": [
				"${env:windir}\\Sysnative\\cmd.exe",
				"${env:windir}\\System32\\cmd.exe"
			],
			"args": [],
			"icon": "terminal-cmd",
			"env": {
				"PATH": "${env:VSCODE_PORTABLE}\\..;${env:PATH}"
			}
		},
	},

	// =========================================================
	// 外観のカスタマイズ
	// =========================================================
	"workbench.colorCustomizations": {
		"editorError.foreground": "#ff000080",
		"editorWarning.foreground": "#ff000080",

		"minimap.errorHighlight": "#ff000040",
		"minimap.warningHighlight": "#00000000",

		"errorLens.errorForeground": "#ff8888",      // 柔らかいサーモンピンクの文字
		"errorLens.warningForeground": "#ffcc00",    // 柔らかい黄色の文字
		"errorLens.infoForeground": "#88bbff"        // 柔らかい水色の文字
	},

	"problems.decorations.enabled": false,
	"explorer.decorations.colors": false,
	"explorer.decorations.badges": false,
	"git.decorations.enabled": false,

	// =========================================================
	// errorLens
	// =========================================================
	"errorLens.margin": "5ch",
	"errorLens.fontStyleItalic": true,
	"errorLens.fontWeight": "300",
	"errorLens.messageBackgroundMode": "message",
	"errorLens.gutterIconsEnabled": false,

	// =========================================================
	// Misc
	// =========================================================
	"window.openFoldersInNewWindow": "on",
	"window.restoreWindows": "none",
	"task.allowAutomaticTasks": "on",
	"debug.onTaskErrors": "abort",
	"vsicons.dontShowNewVersionMessage": true,
	"extensions.ignoreRecommendations": true,
	"git.enableSmartCommit": true,
	"git.confirmSync": false,
	"workbench.activityBar.location": "top",
	"scm.diffDecorations": "none",
	"scm.diffDecorationsGutterAction": "none",
	"chat.disableAIFeatures": true,
	"update.mode": "none",
	"telemetry.telemetryLevel": "off",
	"workbench.enableExperiments": false,
	"workbench.settings.enableNaturalLanguageSearch": false,

	"C_Cpp.default.includePath": [
		// "${workspaceFolder}/**",
		"${fileDirname}",
		// "${fileDirname}/**",
		"${env:LOCALAPPDATA}/Arduino15/packages/arduino/hardware/avr/1.8.7/cores/arduino",
		"${env:LOCALAPPDATA}/Arduino15/packages/arduino/hardware/avr/1.8.7/variants/mega",
		"${env:LOCALAPPDATA}/Arduino15/packages/arduino/hardware/avr/1.8.7/libraries/**",
		"${env:LOCALAPPDATA}/Arduino15/packages/arduino/tools/avr-gcc/7.3.0-atmel3.6.1-arduino7/avr/include",
		"${env:LOCALAPPDATA}/Arduino15/packages/arduino/tools/avr-gcc/7.3.0-atmel3.6.1-arduino7/lib/gcc/avr/7.3.0/include",
		"${env:USERPROFILE}/Documents/Arduino/libraries/**"
	],
	"C_Cpp.default.defines": [
		"ARDUINO=10819",
		"ARDUINO_AVR_MEGA2560",
		"ARDUINO_ARCH_AVR",
		"__AVR_ATmega2560__",
		"F_CPU=16000000L"
	],
	"C_Cpp.default.forcedInclude": [
		"${env:LOCALAPPDATA}/Arduino15/packages/arduino/hardware/avr/1.8.7/cores/arduino/Arduino.h"
	],
	"C_Cpp.default.intelliSenseMode": "gcc-x64",
	"C_Cpp.default.cStandard": "c11",
	"C_Cpp.default.cppStandard": "c++17",
	"C_Cpp.default.compilerPath": "${env:LOCALAPPDATA}/Arduino15/packages/arduino/tools/avr-gcc/7.3.0-atmel3.6.1-arduino7/bin/avr-gcc.exe",

	"C_Cpp.workspaceParsingPriority": "high",
	"C_Cpp.autocomplete": "default",
	"C_Cpp.autocompleteAddParentheses": true,
	"C_Cpp.suggestSnippetsAsSnippets": false,

	"editor.suggest.localityBonus": true,
	"editor.suggest.filterGraceful": true,
	"editor.suggest.snippetsPreventQuickSuggestions": false,
	"window.menuBarVisibility": "compact",

	// =========================================================
	// vscode-neovim
	// nvim / init.lua のパスは start.bat で設定される PATH / XDG_CONFIG_HOME に
	// 依存する。vscode-neovim は setting 上の ${env:X} を解決しないため、ここで
	// 絶対パスを書くと portable モードを壊す。start.bat 経由で起動すること。
	// =========================================================
	"vscode-neovim.ctrlKeysForNormalMode": [
		"a",
		"b",
		"d",
		"e",
		"f",
		"h",
		"i",
		"j",
		"k",
		"l",
		"m",
		"o",
		"r",
		"t",
		"u",
		"v",
		"w",
		"x",
		"y",
		"/",
		"]",
		"q"
	],
	"template.baseName": "mon"
}
