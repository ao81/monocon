{
	// =========================================================
	// Editor
	// =========================================================
	"editor.fontFamily": "'Source Code Pro'",
	"editor.fontLigatures": true,
	"editor.tabSize": 4,
	"editor.insertSpaces": false,
	"editor.autoIndentOnPaste": true,
	"editor.wrappingIndent": "indent",
	"editor.smoothScrolling": true,
	"editor.mouseWheelZoom": true,
	"editor.showFoldingControls": "always",
	"editor.stickyScroll.enabled": false,
	"editor.minimap.side": "left",
	"editor.minimap.size": "fill",
	"editor.minimap.showSlider": "always",
	"editor.codeLens": false,
	"editor.codeLensFontFamily": "'Consolas'",
	"editor.formatOnSave": false,
	"editor.snippetSuggestions": "top",
	"editor.wordBasedSuggestionsMode": "matchingDocuments",
	"editor.quickSuggestions": {
		"comments": "on",
		"strings": "on"
	},

	// =========================================================
	// Formatter (per language)
	// =========================================================
	"[javascript]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
	"[css]":        { "editor.defaultFormatter": "esbenp.prettier-vscode" },
	"[json]":       { "editor.defaultFormatter": "vscode.json-language-features" },
	"[jsonc]":      { "editor.defaultFormatter": "esbenp.prettier-vscode" },
	"[html]":       { "editor.defaultFormatter": "vscode.html-language-features" },
	"[markdown]":   { "editor.defaultFormatter": "DavidAnson.vscode-markdownlint" },
	"[php]":        { "editor.defaultFormatter": "bmewburn.vscode-intelephense-client" },
	"[java]":       { "editor.defaultFormatter": "redhat.java" },
	"[c]":          { "editor.defaultFormatter": "ms-vscode.cpptools" },
	"[cpp]":        { "editor.defaultFormatter": "ms-vscode.cpptools" },
	"[blade]": {
		"editor.autoClosingBrackets": "always",
		"javascript.validate.enable": false
	},

	// =========================================================
	// Prettier
	// =========================================================
	"prettier.tabWidth": 4,
	"prettier.useTabs": true,
	"prettier.printWidth": 180,

	// =========================================================
	// C / C++
	// =========================================================
	"C_Cpp.default.compilerPath": "C:/Program Files (x86)/mingw64/bin/gcc.exe",
	"C_Cpp.formatting": "vcFormat",
	"C_Cpp.intelliSenseEngine": "Tag Parser",
	"C_Cpp.vcFormat.indent.multiLineRelativeTo": "outermostParenthesis",
	"C_Cpp.vcFormat.space.beforeFunctionOpenParenthesis": "remove",
	"C_Cpp.vcFormat.newLine.beforeOpenBrace.block":     "sameLine",
	"C_Cpp.vcFormat.newLine.beforeOpenBrace.function":  "sameLine",
	"C_Cpp.vcFormat.newLine.beforeOpenBrace.lambda":    "sameLine",
	"C_Cpp.vcFormat.newLine.beforeOpenBrace.namespace": "sameLine",
	"C_Cpp.vcFormat.newLine.beforeOpenBrace.type":      "sameLine",
	"C_Cpp.vcFormat.newLine.beforeElse": false,
	"C_Cpp.vcFormat.newLine.beforeCatch": false,
	"C_Cpp.vcFormat.newLine.closeBraceSameLine.emptyFunction": true,
	"clang-format.style": "{ BasedOnStyle: LLVM, IndentWidth: 4, UseTab: Always, TabWidth: 4 }",
	"clang-format.fallbackStyle": "LLVM",

	// =========================================================
	// Code Runner
	// =========================================================
	"code-runner.runInTerminal": true,
	"code-runner.fileDirectoryAsCwd": true,
	"code-runner.executorMap": {
		"c":    "gcc -o a.out $fileName && a.out",
		"cpp":  "chcp 65001 > /dev/null && g++ -std=c++23 -o a.out $fileName && a.out -mconsole",
		"go":   "go run .",
		"java": "javac $fileName && java -cp .. tmp.${fileBasenameNoExtension}",
		"rust": "cargo run"
	},
	"code-runner.executorMapByGlob": {
		"pom.xml": "cd $dir && mvn clean package"
	},

	// =========================================================
	// Terminal
	// =========================================================
	"terminal.integrated.fontFamily": "monospace",
	"terminal.integrated.gpuAcceleration": "on",
	"terminal.integrated.unicodeVersion": "11",
	"terminal.integrated.detectLocale": "off",
	"terminal.integrated.enableMultiLinePasteWarning": "never",
	"terminal.integrated.allowedLinkSchemes": [
		"file", "http", "https", "mailto", "vscode", "vscode-insiders", "ms-settings"
	],
	"terminal.integrated.suggest.quickSuggestions": {
		"commands": "on",
		"arguments": "on",
		"unknown": "on"
	},
	"terminal.integrated.defaultProfile.windows": "Command Prompt",
	"terminal.integrated.profiles.windows": {
		"PowerShell": {
			"source": "PowerShell",
			"icon": "terminal-powershell"
		},
		"Command Prompt": {
			"path": ["${env:windir}\\Sysnative\\cmd.exe", "${env:windir}\\System32\\cmd.exe"],
			"args": [],
			"icon": "terminal-cmd"
		},
		"Git Bash": {
			"source": "Git Bash"
		},
		"Ubuntu (WSL)": {
			"path": "C:\\WINDOWS\\System32\\wsl.exe",
			"args": ["-d", "Ubuntu"]
		}
	},

	// =========================================================
	// Git
	// =========================================================
	"git.autofetch": true,
	"git.enableSmartCommit": true,
	"git.confirmSync": false,
	"git.ignoreRebaseWarning": true,
	"git.ignoreMissingGitWarning": true,
	"git.openRepositoryInParentFolders": "never",
	"git.suggestSmartCommit": false,

	// =========================================================
	// Workbench
	// =========================================================
	"workbench.startupEditor": "none",
	"workbench.iconTheme": "vscode-icons",
	"workbench.editor.empty.hint": "hidden",
	"workbench.editor.enablePreview": false,
	"workbench.secondarySideBar.defaultVisibility": "hidden",
	"workbench.settings.applyToAllProfiles": [
		"editor.tabSize",
		"editor.formatOnSave",
		"editor.fontFamily",
		"css.lint.unknownAtRules",
		"scss.lint.unknownAtRules"
	],

	// =========================================================
	// Explorer
	// =========================================================
	"explorer.confirmDelete": false,
	"explorer.confirmDragAndDrop": false,
	"explorer.confirmPasteNative": false,
	"explorer.compactFolders": false,
	"explorer.fileNesting.patterns": {
		"*.ts":           "${capture}.js",
		"*.js":           "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
		"*.jsx":          "${capture}.js",
		"*.tsx":          "${capture}.ts",
		"tsconfig.json":  "tsconfig.*.json",
		"package.json":   "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb, bun.lock",
		"*.cs":           "${capture}.designer.cs,${capture}.g.cs,${capture}.generated.cs,${capture}.run.json,${capture}.settings.json,${capture}.settings.*.json",
		"*.csproj":       "${capture}.csproj.user",
		"*.json":         "${capture}.Development.json",
		"*.cshtml":       "${capture}.cshtml.cs,${capture}.cshtml.css",
		"*.razor":        "${capture}.razor.cs,${capture}.razor.css",
		"*.resx":         "${capture}.Designer.cs",
		"*.xaml":         "${capture}.xaml.cs",
		"*.sqlite":       "${capture}.${extname}-*",
		"*.db":           "${capture}.${extname}-*",
		"*.sqlite3":      "${capture}.${extname}-*",
		"*.db3":          "${capture}.${extname}-*",
		"*.sdb":          "${capture}.${extname}-*",
		"*.s3db":         "${capture}.${extname}-*"
	},

	// =========================================================
	// CSS / SCSS / Less lint
	// =========================================================
	"css.lint.unknownAtRules": "ignore",
	"css.lint.unknownProperties": "ignore",
	"scss.lint.unknownAtRules": "ignore",
	"less.lint.unknownAtRules": "ignore",

	// =========================================================
	// Tailwind CSS
	// =========================================================
	"tailwindCSS.includeLanguages": {
		"plaintext": "html",
		"php": "html"
	},
	"tailwindCSS.experimental.classRegex": [
		["@apply\\s+([^;]+)", "([^\\s;]+)"]
	],

	// =========================================================
	// HTML
	// =========================================================
	"html.format.extraLiners": "head, body, /html",

	// =========================================================
	// Live Server
	// =========================================================
	"liveServer.settings.port": 5502,
	"liveServer.settings.useWebExt": true,
	"liveServer.settings.donotShowInfoMsg": true,
	"liveServer.settings.donotVerifyTags": true,
	"liveServer.settings.proxy": {
		"enable": true,
		"baseUri": "/",
		"proxyUri": "http://localhost:80/hoge"
	},

	// =========================================================
	// PHP
	// =========================================================
	"php.validate.executablePath": "",
	"phpserver.phpPath": "C:\\xampp\\php\\php.exe",

	// =========================================================
	// Java
	// =========================================================
	"java.jdt.ls.java.home": "C:\\Program Files\\Java\\jdk-24",

	// =========================================================
	// Go
	// =========================================================
	"go.toolsManagement.autoUpdate": true,

	// =========================================================
	// Rust
	// =========================================================
	"rust-analyzer.cargo.autoreload": true,

	// =========================================================
	// Arduino
	// =========================================================
	"arduino.path": "C:\\Users\\ao\\AppData\\Local\\Programs\\Arduino IDE",
	"arduino.commandPath": "arduino-cli",
	"arduino.logLevel": "info",
	"arduino.enableUSBDetection": true,
	"arduino.disableTestingOpen": false,
	"arduino.skipHeaderProvider": false,
	"arduino.defaultBaudRate": 9600,
	"arduino.additionalUrls": [
		"https://dl.espressif.com/dl/package_esp32_index.json"
	],
	"arduino.ignoreBoards": [],
	"arduino-community-cli.path": "C:\\Users\\ao\\Downloads\\arduino-cli_1.3.1_Windows_64bit\\arduino-cli.exe",

	// =========================================================
	// File associations
	// =========================================================
	"files.associations": {
		"*.ino": "c",
		"*.php": "php"
	},

	// =========================================================
	// Vim
	// =========================================================
	"vim.statusBarColors.normal": "",
	"vim.statusBarColors.insert": "",
	"vim.commandLineModeKeyBindings": [],
	"vim.normalModeKeyBindingsNonRecursive": [
		{ "before": ["<C-c>"], "commands": [] }
	],
	"vim.insertModeKeyBindings": [
		{ "before": ["<C-c>"], "commands": ["editor.action.clipboardCopyAction"] }
	],

	// =========================================================
	// Indent Rainbow
	// =========================================================
	"indentRainbow.colors": [
		"rgba(255,255,64,0.07)",
		"rgba(127,255,127,0.07)",
		"rgba(255,127,255,0.07)",
		"rgba(79,236,236,0.07)"
	],
	"indentRainbow.errorColor": "rgba(255,255,255,0.3)",
	"indentRainbow.updateDelay": 10,

	// =========================================================
	// GitLens
	// =========================================================
	"gitlens.ai.model": "vscode",
	"gitlens.ai.vscode.model": "copilot:gpt-4.1",
	"gitlens.graph.minimap.dataType": "lines",
	"gitlens.graph.minimap.additionalTypes": [
		"stashes", "tags", "localBranches", "remoteBranches", "pullRequests"
	],

	// =========================================================
	// Security
	// =========================================================
	"security.workspace.trust.enabled": false,
	"security.workspace.trust.untrustedFiles": "open",
	"security.allowedUNCHosts": ["wsl.localhost"],

	// =========================================================
	// Misc
	// =========================================================
	"window.openFoldersInNewWindow": "on",
	"window.restoreWindows": "none",
	"task.allowAutomaticTasks": "on",
	"powershell.promptToUpdatePowerShell": false,
	"debug.onTaskErrors": "abort",
	"vsicons.dontShowNewVersionMessage": true,
	"vsixViewer.showBadge": true,
	"extensions.ignoreRecommendations": true,
	"claudeCode.preferredLocation": "panel",
	"chat.viewSessions.orientation": "stacked",
	"chat.disableAIFeatures": true,
	"github.copilot.enable": {
		"*": false,
		"plaintext": false,
		"markdown": false,
		"scminput": false
	}
}