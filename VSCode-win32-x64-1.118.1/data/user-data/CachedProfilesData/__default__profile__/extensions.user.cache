ackName":"toggleFoldersAllDefaultIconPresetCommand","enablement":"!isWeb"},{"command":"vscode-icons.hideExplorerArrowsPreset","title":{"value":"エクスプローラーのフォルダ矢印表示の切り替え (ユーザー設定)","original":"Toggle Explorer Folder Arrows Visibility (User Level)"},"category":"Icons","callbackName":"toggleHideExplorerArrowsPresetCommand","enablement":"!isWeb"},{"command":"vscode-icons.restoreIcons","title":{"value":"アイコン設定の復元","original":"Restore Default Icon Manifest"},"category":"Icons","callbackName":"restoreDefaultManifestCommand","enablement":"!isWeb"},{"command":"vscode-icons.resetProjectDetectionDefaults","title":{"value":"プロジェクト検出設定をリセット","original":"Reset Project Detection Defaults"},"category":"Icons","callbackName":"resetProjectDetectionDefaultsCommand","enablement":"!isWeb"}],"configuration":{"title":"vscode-icons","properties":{"vsicons.dontShowNewVersionMessage":{"type":"boolean","default":false,"description":"'true'に設定すると、新バージョンの通知を表示しません。"},"vsicons.dontShowConfigManuallyChangedMessage":{"type":"boolean","default":false,"description":"'true'に設定すると、設定を変更したときに「再読み込み」のメッセージを表示しません。"},"vsicons.projectDetection.autoReload":{"type":"boolean","default":false,"description":"'true'に設定すると、プロジェクト検出時に拡張機能を自動で再読み込みします。"},"vsicons.projectDetection.disableDetect":{"type":"boolean","default":false,"description":"'true'に設定すると、プロジェクト検出を行いません。"},"vsicons.presets.angular":{"type":"boolean","default":false,"description":"'true'に設定すると、Angularで利用されるいくつかのパターンを検出するようになります。"},"vsicons.presets.nestjs":{"type":"boolean","default":false,"description":"'true'に設定すると、NestJSで利用されるいくつかのパターンを検出するようになります。"},"vsicons.presets.jsOfficial":{"type":"boolean","default":false,"description":"'true'に設定すると、公式JSアイコンを使用します。"},"vsicons.presets.tsOfficial":{"type":"boolean","default":false,"description":"'true'に設定すると、公式のTSアイコンを使用します。"},"vsicons.presets.jsonOfficial":{"type":"boolean","default":false,"description":"'true'に設定すると、公式のJSONアイコンを使用します。"},"vsicons.presets.yamlOfficial":{"type":"boolean","default":false,"descrip